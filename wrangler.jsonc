// Cloudflare Worker config: serves the Angular build + API proxy (see worker/index.js).
//
// Two environments, both deployed by Cloudflare Workers Builds (see DEPLOYMENT.md):
//   - top-level (prod):  worker "vesaweb",     vesa.gg + www.vesa.gg,  deploys from `release`
//   - env.dev:           worker "vesaweb-dev", dev.vesa.gg,            deploys from `main`
{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  // Top-level name MUST stay "vesaweb" (the prod worker). Cloudflare's
  // config-sync bot (PRs #54/#55) renames it to "vesaweb-dev" because its
  // name check ignores --env; close those PRs, never merge them — merging
  // makes release deploys land on the dev worker and drag the vesa.gg
  // custom domains with them.
  "name": "vesaweb",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist/angular-app/browser",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  // Custom domains: wrangler creates the DNS records and certs on deploy.
  // The vesa.gg zone must not already have conflicting A/CNAME records on
  // the apex or www (delete any registrar placeholder records first).
  "routes": [
    { "pattern": "vesa.gg", "custom_domain": true },
    { "pattern": "www.vesa.gg", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  // Deployed as worker "vesaweb-dev". Inherits main/assets/compatibility_date;
  // routes are intentionally not inherited, so this env only claims dev.vesa.gg.
  "env": {
    "dev": {
      "routes": [
        { "pattern": "dev.vesa.gg", "custom_domain": true }
      ],"name": "vesaweb-dev"
    }
  }
}
